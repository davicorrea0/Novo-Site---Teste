{
  "require": {
    "php": ">=8.1",
    "johnpbloch/wordpress": "*",
    "phpmailer/phpmailer": "^6.1",
    "k13/image_optimize": "^1.0",
    "k13/integration-social": "*"
  },
  "extra": {
    "wordpress-install-dir": "wp",
    "installer-paths": {
      "content/plugins/{$name}/": [
        "type:wordpress-plugin"
      ]
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://k13-agencia-web.repo.repman.io"
    }
  ],
  "config": {
    "allow-plugins": {
      "johnpbloch/wordpress-core-installer": true,
      "composer/installers": true
    }
  },
  "require-dev": {
    "larapack/dd": "1.*"
  }
}
